{
  "name": "loom",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/account",
    "packages/guardian",
    "packages/deployment"
  ],
  "scripts": {
    "core:build": "tsc -p packages/core/tsconfig.json",
    "core:test": "npm run core:build && npm --prefix packages/core test",
    "compile:solc": "solcjs --base-path . --include-path . --bin --abi -o out-solc",
    "coverage:check": "node tools/quality/check-coverage-gate.mjs",
    "certora:program:test": "node --test tools/formal/validate-certora-program.test.mjs",
    "certora:program:check": "node tools/formal/validate-certora-program.mjs",
    "certora:install": "node tools/formal/certora-local.mjs install",
    "certora:version": "node tools/formal/certora-local.mjs version",
    "certora:compile:authority": "node tools/formal/certora-local.mjs compile formal/certora/conf/loom-account-authority.conf",
    "certora:compile:initialization": "node tools/formal/certora-local.mjs compile formal/certora/conf/loom-account-initialization.conf",
    "certora:run:authority": "node tools/formal/certora-local.mjs run formal/certora/conf/loom-account-authority.conf",
    "certora:run:initialization": "node tools/formal/certora-local.mjs run formal/certora/conf/loom-account-initialization.conf",
    "halmos:install": "node tools/formal/halmos-local.mjs install",
    "halmos:version": "node tools/formal/halmos-local.mjs version",
    "halmos:test": "node tools/formal/halmos-local.mjs test",
    "lean:build": "node tools/formal/lean-local.mjs build",
    "ci:program:test": "node --test tools/ci/validate-ci-program.test.mjs",
    "ci:program:check": "node tools/ci/validate-ci-program.mjs",
    "deps:audit": "node tools/quality/audit-dependencies.mjs",
    "docs:check": "node tools/quality/validate-doc-links.mjs",
    "fixtures:check": "node tools/evidence/validate-webauthn-fixtures.mjs",
    "fixtures:test": "node --test tools/evidence/validate-webauthn-fixtures.test.mjs",
    "fixtures:release": "node tools/evidence/validate-webauthn-fixtures.mjs --require-complete",
    "test:unit": "forge test --match-path \"test/unit/**/*.t.sol\"",
    "test:integration": "forge test --match-path \"test/integration/**/*.t.sol\"",
    "test:evidence": "forge test --match-path \"test/evidence/**/*.t.sol\"",
    "test:invariant": "forge test --match-path \"test/invariant/**/*.t.sol\"",
    "test:regression": "forge test --match-path \"test/regression/**/*.t.sol\"",
    "test:e2e": "node --test test/e2e/wallet-engine.e2e.test.mjs",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:evidence && npm run test:regression && npm run test:invariant && npm run test:e2e",
    "formal:program:test": "node --test tools/formal/validate-formal-program.test.mjs",
    "formal:program:check": "node tools/formal/validate-formal-program.mjs",
    "kontrol:program:test": "node --test tools/formal/validate-kontrol-program.test.mjs",
    "kontrol:program:check": "node tools/formal/validate-kontrol-program.mjs",
    "bundler:qualification:test": "node --test tools/evidence/validate-bundler-qualification.test.mjs",
    "bundler:qualification:check": "node tools/evidence/validate-bundler-qualification.mjs",
    "bundler:qualification:run": "node tools/evidence/run-bundler-qualification.mjs",
    "bundler:qualification:runner:test": "node --test tools/evidence/run-bundler-qualification.test.mjs",
    "bundler:smoke:test": "node --test tools/evidence/bundler-smoke.test.mjs",
    "deployment:manifest:test": "node --test tools/evidence/validate-deployment-manifest.test.mjs",
    "deployment:manifest:build": "node tools/evidence/build-deployment-manifest.mjs",
    "deployment:manifest:build:test": "node --test tools/evidence/build-deployment-manifest.test.mjs",
    "deployment:manifest:check": "node tools/evidence/validate-deployment-manifest.mjs",
    "deployment:wallet:test": "npm --prefix packages/deployment test",
    "deployment:sepolia:summary": "node tools/evidence/summarize-sepolia-deployment.mjs",
    "deployment:sepolia:summary:test": "node --test tools/evidence/summarize-sepolia-deployment.test.mjs",
    "keystore:profile:test": "node --test tools/evidence/validate-keystore-proof-profile.test.mjs",
    "keystore:profile:check": "node tools/evidence/validate-keystore-proof-profile.mjs",
    "kohaku:stack:test": "node --test tools/evidence/validate-kohaku-stack.test.mjs",
    "kohaku:stack:check": "node tools/evidence/validate-kohaku-stack.mjs",
    "privacy:profile:test": "node --test tools/evidence/validate-privacy-adapter-profile.test.mjs",
    "privacy:profile:check": "node tools/evidence/validate-privacy-adapter-profile.mjs",
    "privacy:railgun:rehearsal": "node tools/evidence/run-railgun-rehearsal.mjs",
    "account:test": "npm --prefix packages/account test",
    "guardian:test": "npm --prefix packages/guardian test",
    "guardian:evidence:build": "node tools/evidence/build-guardian-onboarding-evidence.mjs",
    "privacy:test": "npm --prefix packages/privacy test",
    "sdk:test": "npm --prefix packages/sdk ci && npm --prefix packages/sdk test",
    "sdk:types:check": "tsc -p tools/sdk/type-fixture",
    "sdk:calldata:generate": "node tools/sdk/generate-sdk-calldata-fixture.mjs",
    "rehearsal:local": "node tools/evidence/rehearse-local-lifecycle.mjs",
    "rehearsal:live:test": "node --test tools/evidence/validate-live-rehearsal.test.mjs",
    "rehearsal:live:check": "node tools/evidence/validate-live-rehearsal.mjs",
    "site:build": "npm --prefix docs/site run build && node tools/site/copy-site-public.mjs",
    "site:check": "node tools/site/validate-site.mjs",
    "site:dev": "npm --prefix docs/site run dev",
    "verify:quick": "node tools/ci/verify.mjs",
    "verify": "node tools/ci/verify.mjs --full",
    "e2e:devnet": "node tools/e2e/devnet-lifecycle.mjs",
    "deployment:gas": "node tools/deployment/deployment-gas-report.mjs"
  },
  "devDependencies": {
    "js-sha3": "0.9.3",
    "solc": "0.8.35",
    "typescript": "5.9.3"
  },
  "optionalDependencies": {
    "@foundry-rs/anvil-win32-amd64": "1.7.1",
    "@foundry-rs/forge-win32-amd64": "1.7.1"
  },
  "overrides": {
    "tmp": "0.2.7"
  }
}
