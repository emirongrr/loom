{
  "name": "loom",
  "private": true,
  "scripts": {
    "compile:solc": "solcjs --base-path . --include-path . --bin --abi -o out-solc",
    "coverage:check": "node tools/check-coverage-gate.mjs",
    "certora:program:test": "node --test tools/validate-certora-program.test.mjs",
    "certora:program:check": "node tools/validate-certora-program.mjs",
    "certora:install": "node tools/certora-local.mjs install",
    "certora:version": "node tools/certora-local.mjs version",
    "certora:compile:authority": "node tools/certora-local.mjs compile formal/certora/conf/loom-account-authority.conf",
    "certora:compile:initialization": "node tools/certora-local.mjs compile formal/certora/conf/loom-account-initialization.conf",
    "certora:run:authority": "node tools/certora-local.mjs run formal/certora/conf/loom-account-authority.conf",
    "certora:run:initialization": "node tools/certora-local.mjs run formal/certora/conf/loom-account-initialization.conf",
    "halmos:install": "node tools/halmos-local.mjs install",
    "halmos:version": "node tools/halmos-local.mjs version",
    "halmos:test": "node tools/halmos-local.mjs test",
    "lean:build": "node tools/lean-local.mjs build",
    "ci:program:test": "node --test tools/validate-ci-program.test.mjs",
    "ci:program:check": "node tools/validate-ci-program.mjs",
    "deps:audit": "node tools/audit-dependencies.mjs",
    "docs:check": "node tools/validate-doc-links.mjs",
    "fixtures:check": "node tools/validate-webauthn-fixtures.mjs",
    "fixtures:test": "node --test tools/validate-webauthn-fixtures.test.mjs tools/webauthn-fixture-negative-cases.test.mjs",
    "fixtures:release": "node tools/validate-webauthn-fixtures.mjs --require-complete",
    "formal:program:test": "node --test tools/validate-formal-program.test.mjs",
    "formal:program:check": "node tools/validate-formal-program.mjs",
    "kontrol:program:test": "node --test tools/validate-kontrol-program.test.mjs",
    "kontrol:program:check": "node tools/validate-kontrol-program.mjs",
    "bundler:qualification:test": "node --test tools/validate-bundler-qualification.test.mjs",
    "bundler:qualification:check": "node tools/validate-bundler-qualification.mjs",
    "bundler:qualification:run": "node tools/run-bundler-qualification.mjs",
    "bundler:qualification:runner:test": "node --test tools/run-bundler-qualification.test.mjs",
    "bundler:smoke:test": "node --test tools/bundler-smoke.test.mjs",
    "deployment:manifest:test": "node --test tools/validate-deployment-manifest.test.mjs",
    "deployment:manifest:check": "node tools/validate-deployment-manifest.mjs",
    "keystore:profile:test": "node --test tools/validate-keystore-proof-profile.test.mjs",
    "keystore:profile:check": "node tools/validate-keystore-proof-profile.mjs",
    "kohaku:stack:test": "node --test tools/validate-kohaku-stack.test.mjs",
    "kohaku:stack:check": "node tools/validate-kohaku-stack.mjs",
    "privacy:profile:test": "node --test tools/validate-privacy-adapter-profile.test.mjs",
    "privacy:profile:check": "node tools/validate-privacy-adapter-profile.mjs",
    "privacy:railgun:rehearsal": "node scripts/privacy/run-railgun-rehearsal.mjs",
    "account:test": "npm --prefix packages/account test",
    "guardian:test": "npm --prefix packages/guardian test",
    "guardian:evidence:build": "node scripts/guardian/build-onboarding-evidence.mjs",
    "privacy:test": "npm --prefix packages/privacy test",
    "sdk:test": "npm --prefix packages/sdk ci && npm --prefix packages/sdk test",
    "sdk:types:check": "tsc -p tools/sdk-type-fixture",
    "sdk:calldata:generate": "node tools/generate-sdk-calldata-fixture.mjs",
    "rehearsal:local": "node tools/rehearse-local-lifecycle.mjs",
    "rehearsal:live:test": "node --test tools/validate-live-rehearsal.test.mjs",
    "rehearsal:live:check": "node tools/validate-live-rehearsal.mjs",
    "site:build": "npm --prefix docs/site run build && node tools/copy-site-public.mjs",
    "site:check": "node tools/validate-site.mjs",
    "site:dev": "npm --prefix docs/site run dev",
    "verify:quick": "node tools/verify.mjs",
    "verify": "node tools/verify.mjs --full"
  },
  "devDependencies": {
    "js-sha3": "0.9.3",
    "solc": "0.8.35",
    "typescript": "5.9.3"
  },
  "optionalDependencies": {
    "@foundry-rs/forge-win32-amd64": "1.7.1"
  },
  "overrides": {
    "tmp": "0.2.7"
  }
}
