{
  "name": "loom",
  "private": true,
  "scripts": {
    "compile:solc": "solcjs --base-path . --include-path . --bin --abi -o out-solc",
    "coverage:check": "node tools/check-coverage-gate.mjs",
    "deps:audit": "node tools/audit-dependencies.mjs",
    "docs:check": "node tools/validate-doc-links.mjs",
    "fixtures:check": "node tools/validate-webauthn-fixtures.mjs",
    "fixtures:release": "node tools/validate-webauthn-fixtures.mjs --require-complete",
    "account:test": "npm --prefix packages/account test",
    "guardian:test": "npm --prefix packages/guardian test",
    "privacy:test": "npm --prefix packages/privacy test",
    "rehearsal:local": "node tools/rehearse-local-lifecycle.mjs",
    "rehearsal:live:check": "node tools/validate-live-rehearsal.mjs",
    "site:build": "npm --prefix docs/site run build && node tools/copy-site-public.mjs",
    "site:check": "node tools/validate-site.mjs",
    "site:dev": "npm --prefix docs/site run dev",
    "verify:quick": "node tools/verify.mjs",
    "verify": "node tools/verify.mjs --full"
  },
  "devDependencies": {
    "js-sha3": "0.8.0",
    "solc": "0.8.35"
  },
  "optionalDependencies": {
    "@foundry-rs/forge-win32-amd64": "1.7.1"
  },
  "overrides": {
    "tmp": "0.2.7"
  }
}
