{
  "name": "@loom/cli",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "@loom/cli",
      "version": "0.0.0",
      "dependencies": {
        "@loom/core": "file:../core",
        "@loom/deployment": "file:../deployment",
        "@loom/sdk": "file:../sdk"
      },
      "bin": {
        "loom": "bin/loom.mjs"
      }
    },
    "../core": {
      "name": "@loom/core",
      "version": "0.0.0",
      "dependencies": {
        "ajv": "^8.17.1",
        "viem": "^2.55.1"
      }
    },
    "../deployment": {
      "name": "@loom/deployment",
      "version": "0.0.0",
      "dependencies": {
        "@loom/core": "file:../core",
        "js-sha3": "0.9.3"
      }
    },
    "../sdk": {
      "name": "@loom/sdk",
      "version": "0.0.0",
      "dependencies": {
        "@loom/core": "file:../core",
        "js-sha3": "0.8.0"
      }
    },
    "node_modules/@loom/core": {
      "resolved": "../core",
      "link": true
    },
    "node_modules/@loom/deployment": {
      "resolved": "../deployment",
      "link": true
    },
    "node_modules/@loom/sdk": {
      "resolved": "../sdk",
      "link": true
    }
  }
}
