{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loom anonymous WebAuthn assertion fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "matrixId",
    "collectorVersion",
    "capturedAt",
    "platform",
    "platformVersion",
    "browser",
    "browserVersion",
    "authenticator",
    "authenticatorClass",
    "transports",
    "userAgentHash",
    "rpId",
    "origin",
    "publicKeyX",
    "publicKeyY",
    "credentialIdHash",
    "challenge",
    "authenticatorData",
    "clientDataJSON",
    "r",
    "s",
    "expected",
    "negativeMutations",
    "privacy",
    "provenance"
  ],
  "properties": {
    "version": { "const": 1 },
    "evidenceKind": { "enum": ["corpus", "reference", "virtual"] },
    "matrixId": { "type": "string", "pattern": "^[a-z0-9-]+$", "maxLength": 80 },
    "collectorVersion": { "type": "string", "pattern": "^webauthn-fixture-collector@[0-9]+\\.[0-9]+\\.[0-9]+$", "maxLength": 40 },
    "capturedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "platform": { "type": "string", "maxLength": 80 },
    "platformVersion": { "type": "string", "maxLength": 80 },
    "browser": { "type": "string", "maxLength": 80 },
    "browserVersion": { "type": "string", "maxLength": 80 },
    "authenticator": { "type": "string", "maxLength": 80 },
    "authenticatorClass": { "enum": ["platform", "roaming"] },
    "transports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["ble", "hybrid", "internal", "nfc", "smart-card", "usb"] }
    },
    "userAgentHash": { "$ref": "#/$defs/hex32" },
    "rpId": { "type": "string", "maxLength": 253 },
    "origin": { "type": "string", "maxLength": 256 },
    "publicKeyX": { "$ref": "#/$defs/hex32" },
    "publicKeyY": { "$ref": "#/$defs/hex32" },
    "credentialIdHash": { "$ref": "#/$defs/hex32" },
    "challenge": { "$ref": "#/$defs/hex32" },
    "authenticatorData": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$", "maxLength": 2050 },
    "clientDataJSON": { "type": "string", "maxLength": 1024 },
    "r": { "$ref": "#/$defs/hex32" },
    "s": { "$ref": "#/$defs/hex32" },
    "expected": { "type": "boolean" },
    "negativeMutations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "challenge",
          "origin",
          "rpIdHash",
          "userVerificationFlag",
          "signature",
          "payloadLength"
        ]
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["containsRawUserAgent", "containsUserIdentifiers", "containsAttestationObject"],
      "properties": {
        "containsRawUserAgent": { "const": false },
        "containsUserIdentifiers": { "const": false },
        "containsAttestationObject": { "const": false }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captureMode",
        "collectorSource",
        "collectorSourceHash",
        "requiresFreshCredential",
        "reviewedForPII",
        "negativeCaseManifestHash"
      ],
      "properties": {
        "captureMode": { "enum": ["local-secure-context", "reference-vector", "virtual-authenticator"] },
        "collectorSource": {
          "enum": [
            "tools/webauthn-fixture/collector.html",
            "tools/webauthn-fixture/generate-reference-fixture.mjs",
            "tools/webauthn-fixture/virtual-runner.mjs"
          ]
        },
        "collectorSourceHash": { "$ref": "#/$defs/hex32" },
        "requiresFreshCredential": { "const": true },
        "reviewedForPII": { "const": true },
        "negativeCaseManifestHash": { "$ref": "#/$defs/hex32" }
      }
    },
    "notes": { "type": "string", "maxLength": 500 }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    }
  }
}
