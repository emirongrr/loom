{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loom WebAuthn fixture negative-case manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "fixtureMatrixId",
    "fixtureChallenge",
    "fixtureCredentialIdHash",
    "fixturePublicKeyHash",
    "mutations",
    "manifestHash"
  ],
  "properties": {
    "version": { "const": 1 },
    "fixtureMatrixId": { "type": "string", "pattern": "^[a-z0-9-]+$", "maxLength": 80 },
    "fixtureChallenge": { "$ref": "#/$defs/hex32" },
    "fixtureCredentialIdHash": { "$ref": "#/$defs/hex32" },
    "fixturePublicKeyHash": { "$ref": "#/$defs/hex32" },
    "manifestHash": { "$ref": "#/$defs/hex32" },
    "mutations": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "expected", "fixtureMatrixId", "mutates", "reason"],
        "properties": {
          "name": {
            "enum": [
              "challenge",
              "origin",
              "rpIdHash",
              "userVerificationFlag",
              "signature",
              "payloadLength"
            ]
          },
          "expected": { "const": false },
          "fixtureMatrixId": { "type": "string", "pattern": "^[a-z0-9-]+$", "maxLength": 80 },
          "mutates": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "maxLength": 80 }
          },
          "reason": { "type": "string", "maxLength": 240 }
        }
      }
    }
  },
  "$defs": {
    "hex32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    }
  }
}
