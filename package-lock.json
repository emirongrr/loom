{
  "name": "loom",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "loom",
      "workspaces": [
        "packages/core",
        "packages/account",
        "packages/guardian",
        "packages/deployment"
      ],
      "devDependencies": {
        "js-sha3": "0.9.3",
        "solc": "0.8.35",
        "typescript": "5.9.3"
      },
      "optionalDependencies": {
        "@foundry-rs/anvil-win32-amd64": "1.7.1",
        "@foundry-rs/forge-win32-amd64": "1.7.1"
      }
    },
    "node_modules/@foundry-rs/anvil-win32-amd64": {
      "version": "1.7.1",
      "cpu": [
        "x64"
      ],
      "license": "MIT OR Apache-2.0",
      "optional": true,
      "os": [
        "win32"
      ],
      "bin": {
        "anvil": "bin/anvil.exe"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@foundry-rs/forge-win32-amd64": {
      "version": "1.7.1",
      "cpu": [
        "x64"
      ],
      "license": "MIT OR Apache-2.0",
      "optional": true,
      "os": [
        "win32"
      ],
      "bin": {
        "forge": "bin/forge.exe"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@loom/account": {
      "resolved": "packages/account",
      "link": true
    },
    "node_modules/@loom/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@loom/deployment": {
      "resolved": "packages/deployment",
      "link": true
    },
    "node_modules/@loom/guardian": {
      "resolved": "packages/guardian",
      "link": true
    },
    "node_modules/command-exists": {
      "version": "1.2.9",
      "dev": true,
      "license": "MIT"
    },
    "node_modules/commander": {
      "version": "8.3.0",
      "dev": true,
      "license": "MIT",
      "engines": {
        "node": ">= 12"
      }
    },
    "node_modules/follow-redirects": {
      "version": "1.16.0",
      "dev": true,
      "funding": [
        {
          "type": "individual",
          "url": "https://github.com/sponsors/RubenVerborgh"
        }
      ],
      "license": "MIT",
      "engines": {
        "node": ">=4.0"
      },
      "peerDependenciesMeta": {
        "debug": {
          "optional": true
        }
      }
    },
    "node_modules/js-sha3": {
      "version": "0.9.3",
      "dev": true,
      "license": "MIT"
    },
    "node_modules/memorystream": {
      "version": "0.3.1",
      "dev": true,
      "engines": {
        "node": ">= 0.10.0"
      }
    },
    "node_modules/semver": {
      "version": "5.7.2",
      "dev": true,
      "license": "ISC",
      "bin": {
        "semver": "bin/semver"
      }
    },
    "node_modules/solc": {
      "version": "0.8.35",
      "dev": true,
      "license": "MIT",
      "dependencies": {
        "command-exists": "^1.2.8",
        "commander": "^8.1.0",
        "follow-redirects": "^1.12.1",
        "js-sha3": "0.8.0",
        "memorystream": "^0.3.1",
        "semver": "^5.5.0",
        "tmp": "0.0.33"
      },
      "bin": {
        "solcjs": "solc.js"
      },
      "engines": {
        "node": ">=12.0.0"
      }
    },
    "node_modules/solc/node_modules/js-sha3": {
      "version": "0.8.0",
      "dev": true,
      "license": "MIT"
    },
    "node_modules/tmp": {
      "version": "0.2.7",
      "resolved": "https://registry.npmjs.org/tmp/-/tmp-0.2.7.tgz",
      "integrity": "sha512-e0votIpp4Uo2AJYSzVHV6xCcawuiez3DzqDAbrTc3YxBkplN6e+dM13ZeIcZnDg/QpSuU2zfZ3rzwY8ukEnaXw==",
      "dev": true,
      "license": "MIT",
      "engines": {
        "node": ">=14.14"
      }
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/account": {
      "name": "@loom/account",
      "version": "0.0.0"
    },
    "packages/core": {
      "name": "@loom/core",
      "version": "0.0.0"
    },
    "packages/deployment": {
      "name": "@loom/deployment",
      "version": "0.0.0",
      "dependencies": {
        "js-sha3": "0.8.0"
      }
    },
    "packages/deployment/node_modules/js-sha3": {
      "version": "0.8.0",
      "license": "MIT"
    },
    "packages/guardian": {
      "name": "@loom/guardian",
      "version": "0.0.0"
    }
  }
}
