# Copy to .env and fill in. .env is gitignored; this template is not.
#
# The sponsor backend starts only when both are set. Without them the page still
# runs and accounts stay counterfactual — nothing here picks a provider or a key
# for you.

# Any Sepolia JSON-RPC endpoint. Read and write; the sponsor sends transactions
# through it.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# The key that PAYS for account creation. It is never account authority: users
# sign their own operations with their passkeys, and this key cannot alter a
# signed operation or control an account it funded.
#
# Use a throwaway key with only testnet funds. Never a key that holds anything
# you would miss, and never one reused on mainnet.
SEPOLIA_SPONSOR_PRIVATE_KEY=0x

# Optional. Defaults shown.
# SPONSOR_PORT=8787
# SPONSOR_DEPOSIT_ETH=0.02
