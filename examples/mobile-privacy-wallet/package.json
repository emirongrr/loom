{
  "name": "@loom/example-mobile-privacy-wallet",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "^20.19.4 || ^22.13.0 || >=24.3.0"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test:gates": "node --test test/release-gates.test.mjs",
    "test:flows": "tsc -p tsconfig.tests.json && node --test dist-tests/test/flows.test.js dist-tests/test/hygiene.test.js",
    "test": "npm run test:gates && npm run test:flows",
    "deploy:connect": "node scripts/connect-deployment.mjs",
    "bundler:local": "node scripts/run-local-bundler.mjs",
    "bootstrap": "node scripts/bootstrap-deployment.mjs",
    "prestart": "node scripts/preflight.mjs",
    "preandroid": "node scripts/preflight.mjs",
    "preios": "node scripts/preflight.mjs",
    "deployment:remove": "node scripts/disconnect-deployment.mjs"
  },
  "dependencies": {
    "@a16z/helios": "^0.11.1",
    "@loom/deployment": "file:../../packages/deployment",
    "@loom/guardian": "file:../../packages/guardian",
    "@loom/privacy": "file:../../packages/privacy",
    "@loom/sdk": "file:../../packages/sdk",
    "expo": "^57.0.4",
    "expo-clipboard": "~57.0.0",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "^57.0.5",
    "expo-modules-core": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "loom-passkey": "file:modules/loom-passkey",
    "loom-screen-privacy": "file:modules/loom-screen-privacy",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "js-sha3": "^0.8.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
