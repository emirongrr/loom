LOOM_WALLET_ENV=development

# Helios is the preferred verified state-read mode. Endpoints are untrusted
# transports supplied by the user or integrator; the checkpoint is the explicit
# weak-subjectivity trust root.
EXPO_PUBLIC_LOOM_STATE_MODE=helios
EXPO_PUBLIC_LOOM_HELIOS_KIND=ethereum
EXPO_PUBLIC_LOOM_HELIOS_NETWORK=sepolia
EXPO_PUBLIC_LOOM_HELIOS_EXECUTION_RPC=
EXPO_PUBLIC_LOOM_HELIOS_CONSENSUS_RPC=
EXPO_PUBLIC_LOOM_HELIOS_CHECKPOINT=
EXPO_PUBLIC_LOOM_HELIOS_VERIFIABLE_API=

# Optional unverified fallback. Use only with EXPO_PUBLIC_LOOM_STATE_MODE=rpc.
EXPO_PUBLIC_LOOM_RPC_URL=

# Required before any account deployment or transaction submission.
EXPO_PUBLIC_LOOM_BUNDLER_URL=
EXPO_PUBLIC_LOOM_ENTRYPOINT=

# Required before account creation. Every EXPO_PUBLIC_ value is shipped in the
# client bundle and is NOT a secret; it is public configuration. None of these
# is defaulted — a missing value blocks account creation instead of assuming a
# chain or origin (see configurationReadiness in src/config/environment.ts).
EXPO_PUBLIC_LOOM_CHAIN_ID=
EXPO_PUBLIC_LOOM_L1_CHAIN_ID=
EXPO_PUBLIC_LOOM_ACCOUNT_FACTORY=
EXPO_PUBLIC_LOOM_PASSKEY_VALIDATOR=
EXPO_PUBLIC_LOOM_P256_VERIFIER_MODE=
EXPO_PUBLIC_LOOM_P256_VERIFIER=

# Passkey relying-party binding. Must match the RP id and origin pinned in the
# native iOS/Android build policy; the JS layer cannot expand the native policy.
EXPO_PUBLIC_LOOM_RP_ID=
EXPO_PUBLIC_LOOM_ORIGIN=

# Optional: path to the committed deployment manifest the app verifies its
# configured addresses against before deploying (see deployment/manifest.example.json).
EXPO_PUBLIC_LOOM_DEPLOYMENT_MANIFEST=

# Required before privacy transfer can be enabled.
EXPO_PUBLIC_LOOM_PRIVACY_PROFILE_PATH=
