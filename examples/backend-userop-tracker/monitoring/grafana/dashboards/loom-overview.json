{
  "title": "Loom Overview",
  "uid": "loom-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "loom"
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
